# CivicCrowd Docker Environment
# Copy this file to .env and fill in values before running docker compose.
# Docker Compose reads .env automatically from the project root.
# NEVER commit the .env file with real secrets.

# Generate keys with: php -r "echo 'base64:' . base64_encode(random_bytes(32)) . PHP_EOL;"
APP_KEY=
FRONTEND_APP_KEY=
POSTGRES_PASSWORD=
